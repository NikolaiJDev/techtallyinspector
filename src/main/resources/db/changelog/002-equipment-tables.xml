<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="002-001-devices-table" author="migration">
        <createTable tableName="devices">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="idbase" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="devname" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="whereis" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="address" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="param_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="param_value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="cnt" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="devid" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="stamp" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="child" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="INT" defaultValue="1">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-002-devgroups-table" author="migration">
        <createTable tableName="devgroups">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="parent_id" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-003-device-types-table" author="migration">
        <createTable tableName="device_types">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="icon" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-004-equipment-table" author="migration">
        <createTable tableName="equipment">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="serial_number" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="inventory_number" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
            <column name="device_type_id" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="group_id" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="location" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="responsible_user_id" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="active">
                <constraints nullable="false"/>
            </column>
            <column name="purchase_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="purchase_price" type="DECIMAL(10,2)">
                <constraints nullable="true"/>
            </column>
            <column name="warranty_end_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-005-equipment-history-table" author="migration">
        <createTable tableName="equipment_history">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="equipment_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="action_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="performed_by" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="performed_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="old_values" type="JSON">
                <constraints nullable="true"/>
            </column>
            <column name="new_values" type="JSON">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>